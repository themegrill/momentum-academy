{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"title": "Montserrat & Roboto",
	"slug": "typography-preset-2",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"name": "Montserrat",
					"slug": "montserrat",
					"fontFamily": "Montserrat, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/Montserrat/Montserrat-Regular.ttf"
							]
						},
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/Montserrat/Montserrat-SemiBold.ttf"
							]
						},
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/Montserrat/Montserrat-Bold.ttf"
							]
						}
					]
				},
				{
					"name": "Roboto",
					"slug": "roboto",
					"fontFamily": "Roboto, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/Roboto/Roboto-Regular.ttf"
							],
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontFamily": "Roboto"
						},
						{
							"src": [
								"file:./assets/fonts/Roboto/Roboto-SemiBold.ttf"
							],
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontFamily": "Roboto"
						},
						{
							"src": [
								"file:./assets/fonts/Roboto/Roboto-Bold.ttf"
							],
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontFamily": "Roboto"
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|roboto",
			"fontSize": "var:preset|font-size|medium",
			"letterSpacing": "-0.18px",
			"lineHeight": "1.5"
		},
		"blocks": {
			"core/post-author-name": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-title": {
				"typography": {
					"fontWeight": "400",
					"letterSpacing": "-0.96px"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "400"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontFamily": "var:preset|font-family|roboto",
							"fontWeight": "400",
							"letterSpacing": "-0.14px"
						}
					}
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var:preset|font-family|roboto",
					"fontWeight": "600",
					"letterSpacing": "-0.18px"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontSize": "var:preset|font-size|x-large"
				}
			}
		},
		"elements": {
			"button": {
				"typography": {
					"fontFamily": "var:preset|font-family|roboto",
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "400",
					"letterSpacing": "-0.36px"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "48px",
					"letterSpacing": "-0.96px;"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "38px",
					"letterSpacing": "-0.96px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "32px",
					"letterSpacing": "-0.64px"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "28px",
					"letterSpacing": "-0.56px"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "24px",
					"letterSpacing": "-0.48px"
				}
			}
		}
	}
}
